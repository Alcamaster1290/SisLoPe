{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "watchPatterns": [
      "services/maritime-api/**"
    ]
  },
  "deploy": {
    "startCommand": "npm run heatmap:sync:gfw",
    "cronSchedule": "15 10 * * *",
    "restartPolicyType": "NEVER",
    "restartPolicyMaxRetries": 0
  }
}
