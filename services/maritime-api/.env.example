NODE_ENV=development
PORT=3001
DATABASE_URL=
FRONTEND_ORIGIN=http://localhost:5173
MARITIME_ADMIN_API_KEY=
MARITIME_CACHE_SUMMARY_TTL_SEC=60
MARITIME_CACHE_ALERTS_TTL_SEC=60
MARITIME_CACHE_TIMELINE_TTL_SEC=300
MARITIME_CACHE_HEATMAP_LATEST_TTL_SEC=3600
MARITIME_CACHE_HEATMAP_DAILY_TTL_SEC=21600
MARITIME_ENABLE_WRITE_ENDPOINTS=true
MARITIME_ENABLE_MANUAL_REFRESH=false
MARITIME_REFRESH_COOLDOWN_SEC=900
LOG_LEVEL=info
GFW_API_TOKEN=
GFW_BASE_URL=https://gateway.api.globalfishingwatch.org
GFW_HEATMAP_TARGET_DATE=
GFW_HEATMAP_LAG_DAYS=4
GFW_HEATMAP_H3_RESOLUTION=5
GFW_HEATMAP_SPATIAL_RESOLUTION=LOW
GFW_HEATMAP_VESSEL_TYPES=
GFW_HEATMAP_SOURCE_NAME=global-fishing-watch-public-presence
GFW_HEATMAP_SOURCE_URL=https://globalfishingwatch.org/our-apis/documentation
GFW_HEATMAP_COVERAGE_NOTE=Cobertura referencial de Global Fishing Watch, parcial en corredores fluviales y con latencia aproximada de 96 horas.
GFW_HEATMAP_REGION_GEOJSON=
