{
  "name": "@sislope/maritime-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint .",
    "heatmap:import": "tsx src/scripts/importHeatmapSnapshot.ts",
    "heatmap:sync:gfw": "tsx src/scripts/syncGfwHeatmapDaily.ts",
    "heatmap:sync:gfw:dry-run": "tsx src/scripts/syncGfwHeatmapDaily.ts --dry-run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.6",
    "fastify": "^5.6.1",
    "h3-js": "^4.4.0",
    "lru-cache": "^11.2.2",
    "postgres": "^3.4.7",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.4",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.5.2",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0",
    "vitest": "^4.1.0"
  }
}
