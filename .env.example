# ─── Auth (shared Neon PostgreSQL — same connection as ADEX-Palletizer) ───────
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
SISLOPE_COOKIE_NAME=sislope_refresh_token
SESSION_TTL_DAYS=30
AUTH_COOKIE_SECURE=true
CORS_ORIGIN=https://sis-lo-pe.vercel.app

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_ADEX_URL=https://adex-palletizer.vercel.app
VITE_ALVIN_URL=https://alvin-comex.streamlit.app
VITE_MAP_STYLE_URL=
VITE_USE_INLINE_FALLBACK_STYLE=true
VITE_ENABLE_MARITIME_TRACKING=false
VITE_ENABLE_MARITIME_TRACKING_MAP=false
VITE_MARITIME_API_BASE_URL=

# Data Trade common auth and tracking, opt-in only.
VITE_DATA_TRADE_AUTH_ENABLED=false
VITE_DATA_TRADE_API_URL=
VITE_DATA_TRADE_TRACKING_ENABLED=false
VITE_DATA_TRADE_MODULE_CODE=sislope
